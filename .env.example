# Example environment variables for local development
# Copy this file to `.env.local` and fill in required values.
# `.env` and `.env.local` are gitignored to protect secrets.

# Examples (uncomment and set as needed):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# ELEVENLABS_API_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# DATABASE_URL=

VITE_INTRO_ENABLED=0
VITE_INTRO_DURATION_MS=5000
VITE_CROSSFADE=auto
VITE_HDRI_URL=/assets/hdr/studio_small_09_1k.hdr
VITE_INTRO_STEREO_HALF=bottom

# Analytics - Auto upload to Google Sheets (EASY SETUP!)
# 
# Step 1: Create a Google Sheet with these columns:
#   timestamp | user_id | city | country | duration | experience | zones_visited | most_viewed_zone | zone_time | device | session_end
#
# Step 2: Go to sheetdb.io (free account)
# Step 3: Click "Create API from Google Sheet" and connect your sheet  
# Step 4: Copy the API URL and paste below
#
VITE_ANALYTICS_URL=

# VR Analytics (Keycloak client-credentials) via Netlify Functions
#
# IMPORTANT:
# - Do NOT put KEYCLOAK_CLIENT_SECRET in any VITE_* variable (it would be exposed to users).
# - Set these as Environment Variables in Netlify UI (Site configuration -> Environment variables).
#
# Required (Netlify server-side env vars):
# KEYCLOAK_SERVER_URL=https://keycloak.dev.opensky.co.in
# KEYCLOAK_REALM=opensky-stage
# KEYCLOAK_CLIENT_ID=vr-server-client
# KEYCLOAK_CLIENT_SECRET=...
# VR_API_BASE_URL=...
#
# Optional (frontend toggle; defaults to enabled in production, disabled on localhost):
VITE_VR_API_ENABLED=1
