{
    "name": "nandanavanam",
    "version": "1.0.0",
    "description": "Nandanavanam VR tour (Netlify-ready, Vite + Babylon.js)",
    "main": "agent.js",
    "scripts": {
        "test": "echo \"Use npm run test:e2e (Netlify URL) or npm run test:soak (local build)\"",
        "dev": "vite",
        "dev:http": "set DEV_HTTPS=0&& vite",
        "build": "vite build",
        "preview": "vite preview --port 4173",
        "serve:dist": "http-server dist -p 4173 -s",
        "test:setup": "playwright install chromium webkit",
        "test:soak": "npm run build && playwright test --reporter=list",
        "test:soak:fast": "playwright test --reporter=list",
        "test:e2e": "playwright test --reporter=list",
        "test:e2e:webkit": "playwright test --project=webkit-iphone-12 --project=webkit-iphone-14-pro --project=webkit-ipad --reporter=list",
        "test:e2e:chromium": "playwright test --project=chromium-pixel-7 --project=chromium-galaxy-s9 --reporter=list",
        "generate:manifest": "node ./scripts/generate-experience-manifest.mjs",
        "predev": "npm run generate:manifest",
        "prebuild": "npm run generate:manifest && npm run make:fallbacks && npm run prune:panos:png",
        "prepreview": "npm run generate:manifest",
        "make:fallbacks": "node ./scripts/make-jpeg-fallbacks.mjs",
        "make:fallbacks:ktx2": "node ./scripts/make-jpeg-fallbacks-from-ktx2.mjs",
        "prune:panos:png": "node ./scripts/prune-pano-pngs.mjs",
        "compress:panos": "node ./scripts/compress-panos.mjs",
        "setup:ktx2": "node ./scripts/setup-ktx2-runtime.mjs",
        "compress:panos:ktx2": "node ./scripts/compress-panos-ktx2.mjs",
        "compress:villas:ktx2": "node ./scripts/compress-panos-ktx2.mjs --exp \"Villas Walkthrough\"",
        "compress:villas:ktx2:prune": "node ./scripts/compress-panos-ktx2.mjs --exp \"Villas Walkthrough\" --move-originals"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "devDependencies": {
        "@vitejs/plugin-basic-ssl": "^2.1.0",
        "@vitejs/plugin-legacy": "^7.2.1",
        "http-server": "^14.1.1",
        "rollup": "^4.52.5",
        "sharp": "^0.33.5",
        "vite": "^7.1.4",
        "ws": "^8.18.3"
    },
    "dependencies": {
        "@babylonjs/core": "^8.26.0",
        "@babylonjs/loaders": "^8.26.0",
        "@playwright/test": "^1.57.0"
    },
    "overrides": {
        "semver": "7.5.4"
    },
    "private": "true"
}
